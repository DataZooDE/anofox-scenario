# name: test/sql/scenario_refresh.test
# description: scenario_refresh(): pick up base tables created after the scenario; FK enforcement position
# group: [anofox_scenario]

require anofox_scenario

statement ok
CREATE TABLE products (id INTEGER PRIMARY KEY, name VARCHAR);

statement ok
INSERT INTO products VALUES (1, 'widget');

statement ok
CALL scenario_create('evolving', 'schema grows under me');

statement ok
ATTACH 'evolving' AS s (TYPE scenario);

# a table created in the base AFTER the scenario exists
statement ok
CREATE TABLE orders (order_id INTEGER PRIMARY KEY, product_id INTEGER, amount INTEGER);

statement ok
INSERT INTO orders VALUES (100, 1, 5);

# readable through the scenario (overlay semantics)...
query I
SELECT count(*) FROM s.orders;
----
1

# ...but not writable until refreshed
statement error
INSERT INTO s.orders VALUES (101, 1, 3);
----
<REGEX>:.*created in the base after scenario.*

# refresh creates the missing delta tables
query I
SELECT refreshed_tables FROM scenario_refresh('evolving');
----
1

statement ok
INSERT INTO s.orders VALUES (101, 1, 3);

query II
SELECT order_id, amount FROM s.orders ORDER BY order_id;
----
100	5
101	3

# base still untouched
query I
SELECT count(*) FROM orders;
----
1

# refresh is idempotent
query I
SELECT refreshed_tables FROM scenario_refresh('evolving');
----
0

# --- refresh can declare keys for new keyless tables (codex finding #2) ---------

statement ok
CREATE TABLE metrics (metric_name VARCHAR, val DOUBLE);

statement ok
INSERT INTO metrics VALUES ('cpu', 0.5);

query I
SELECT refreshed_tables FROM scenario_refresh('evolving', key_columns := MAP {'metrics': ['metric_name']});
----
1

statement ok
UPDATE s.metrics SET val = 0.9 WHERE metric_name = 'cpu';

query T
SELECT val::VARCHAR FROM s.metrics;
----
0.9

query T
SELECT val::VARCHAR FROM metrics;
----
0.5

# unknown scenario errors
statement error
SELECT * FROM scenario_refresh('nope');
----
<REGEX>:.*not found.*

# materialized scenarios refuse refresh (would break point-in-time isolation)
statement ok
CALL scenario_create('frozen_copy', mode := 'materialized');

statement error
SELECT * FROM scenario_refresh('frozen_copy');
----
<REGEX>:.*materialized.*

# --- FK position: scenarios skip FK checks; merge-back enforces them -------------

statement ok
CREATE TABLE line_items (
    item_id INTEGER PRIMARY KEY,
    order_id INTEGER REFERENCES orders(order_id),
    qty INTEGER);

statement ok
CALL scenario_create('fk_scen');

statement ok
ATTACH 'fk_scen' AS f (TYPE scenario);

# an orphaned row is accepted inside the scenario (documented v1 semantics:
# FK constraints are not evaluated against the merged state)
statement ok
INSERT INTO f.line_items VALUES (1, 999, 10);

query I
SELECT count(*) FROM f.line_items;
----
1

# ...but promotion into the base enforces the base's FK and rolls back atomically
statement error
SELECT * FROM scenario_merge('fk_scen');
----
<REGEX>:.*(foreign key|Violates foreign key).*

# nothing leaked into the base
query I
SELECT count(*) FROM line_items;
----
0

# fixing the scenario makes the merge pass
statement ok
DELETE FROM f.line_items WHERE item_id = 1;

statement ok
INSERT INTO f.line_items VALUES (1, 100, 10);

query I
SELECT rows_applied FROM scenario_merge('fk_scen');
----
1

query II
SELECT item_id, order_id FROM line_items;
----
1	100

# --- cleanup -----------------------------------------------------------------------

statement ok
DETACH s;

statement ok
DETACH f;

statement ok
CALL scenario_drop('evolving');

statement ok
CALL scenario_drop('frozen_copy');

statement ok
CALL scenario_drop('fk_scen');
