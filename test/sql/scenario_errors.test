# ============================================================================
# DDL Blocking Errors
# ============================================================================

# Error: CREATE TABLE in scenario schema (includes remediation)
statement error
CREATE TABLE _scen_delta_error_test.new_table (id INT);
----
CREATE TABLE is not permitted in scenario schemas. Scenarios use copy-on-write delta tables for modifications. Use delta_create() to enable modifications on existing tables.

# Error: ALTER TABLE in scenario schema (includes remediation)
statement error
ALTER TABLE _scen_delta_error_test.error_test ADD COLUMN new_col INT;
----
ALTER TABLE is not permitted in scenario schemas. Schema modifications cannot be made within scenarios. Tables in scenarios are views that merge base data with delta changes.

# Note: DROP on internal objects (delta tables, merge views) is allowed
# since our extension needs to manage them. Only user-visible operations are blocked.

# ============================================================================
# Stats Errors
# ============================================================================

# Error: scenario_stats for non-existent scenario
statement error
SELECT * FROM scenario_stats('nonexistent_scenario');
----
Scenario 'nonexistent_scenario' does not exist

# ============================================================================
# Cleanup
# ============================================================================

query T
SELECT scenario_drop('delta_error_test');
----
true

statement ok
DROP TABLE error_test;

# Verify cleanup
query I
SELECT COUNT(*) FROM scenario_list();
----
0
