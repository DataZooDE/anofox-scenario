# name: test/sql/attach_persistence.test
# description: Phase 1 WP5: scenario state (registry + deltas) survives database restart
# group: [anofox_scenario]

require anofox_scenario

load __TEST_DIR__/scenario_persistence.db

statement ok
CREATE TABLE forecast (id INTEGER PRIMARY KEY, qty INTEGER);

statement ok
INSERT INTO forecast VALUES (1, 100), (2, 200), (3, 300);

statement ok
CALL scenario_create('persistent', 'survives restarts');

statement ok
ATTACH 'persistent' AS s (TYPE scenario);

statement ok
INSERT INTO s.forecast VALUES (10, 1000);

statement ok
UPDATE s.forecast SET qty = 222 WHERE id = 2;

statement ok
DELETE FROM s.forecast WHERE id = 3;

query II
SELECT id, qty FROM s.forecast ORDER BY id;
----
1	100
2	222
10	1000

statement ok
DETACH s;

restart

# scenario data is durable: reattach and see the same merged state
statement ok
ATTACH 'persistent' AS s2 (TYPE scenario);

query II
SELECT id, qty FROM s2.forecast ORDER BY id;
----
1	100
2	222
10	1000

# base still untouched
query II
SELECT id, qty FROM forecast ORDER BY id;
----
1	100
2	200
3	300

# still writable after restart
statement ok
INSERT INTO s2.forecast VALUES (11, 1100);

query I
SELECT count(*) FROM s2.forecast;
----
4

statement ok
DETACH s2;

statement ok
CALL scenario_drop('persistent');
