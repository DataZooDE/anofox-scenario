# name: test/sql/attach_unsupported.test
# description: Phase 1: deliberately unsupported DML shapes fail with guidance (retired in v0.4/v0.5)
# group: [anofox_scenario]

require anofox_scenario

statement ok
CREATE TABLE forecast (id INTEGER PRIMARY KEY, qty INTEGER);

statement ok
INSERT INTO forecast VALUES (1, 100), (2, 200);

statement ok
CALL scenario_create('u');

statement ok
ATTACH 'u' AS s (TYPE scenario);

# ON CONFLICT
statement error
INSERT INTO s.forecast VALUES (1, 1) ON CONFLICT DO NOTHING;
----
<REGEX>:.*(ON CONFLICT.*not supported|does not support.*ON CONFLICT).*

statement error
INSERT OR REPLACE INTO s.forecast VALUES (1, 1);
----
<REGEX>:.*(ON CONFLICT.*not supported|does not support.*ON CONFLICT).*

# RETURNING
statement error
INSERT INTO s.forecast VALUES (5, 500) RETURNING id;
----
<REGEX>:.*RETURNING.*not supported yet.*

statement error
UPDATE s.forecast SET qty = 1 WHERE id = 1 RETURNING id;
----
<REGEX>:.*RETURNING.*not supported yet.*

statement error
DELETE FROM s.forecast WHERE id = 1 RETURNING id;
----
<REGEX>:.*RETURNING.*not supported yet.*

# PK-column updates
statement error
UPDATE s.forecast SET id = 99 WHERE id = 1;
----
<REGEX>:.*PRIMARY KEY.*not supported yet.*

# MERGE INTO
statement error
MERGE INTO s.forecast USING (SELECT 1 AS id, 1 AS qty) src ON s.forecast.id = src.id WHEN MATCHED THEN UPDATE SET qty = src.qty;
----
<REGEX>:.*(MERGE|not supported|Not implemented).*

# the table is still writable through the supported surface
statement ok
INSERT INTO s.forecast VALUES (5, 500);

query I
SELECT count(*) FROM s.forecast;
----
3

statement ok
DETACH s;

statement ok
CALL scenario_drop('u');
