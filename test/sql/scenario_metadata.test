# name: test/sql/scenario_metadata.test
# description: Test metadata tables are created on extension load
# group: [anofox_scenario]

require anofox_scenario

# Test: _scenario_registry table exists with correct columns
query TTTTTT
SELECT column_name, column_type, "null", "key", "default", extra FROM (DESCRIBE _scenario_registry) ORDER BY 1;
----
base_captured_at	TIMESTAMP	NO	NULL	NULL	NULL
base_schema	VARCHAR	NO	NULL	NULL	NULL
created_at	TIMESTAMP	YES	NULL	current_timestamp	NULL
description	VARCHAR	YES	NULL	NULL	NULL
parent_scenario_id	INTEGER	YES	NULL	NULL	NULL
scenario_id	INTEGER	NO	PRI	NULL	NULL
scenario_name	VARCHAR	NO	UNI	NULL	NULL
schema_name	VARCHAR	NO	UNI	NULL	NULL
status	VARCHAR	YES	NULL	'active'	NULL

# Test: _scenario_tables table exists with correct columns
query TTTTTT
SELECT column_name, column_type, "null", "key", "default", extra FROM (DESCRIBE _scenario_tables) ORDER BY 1;
----
base_row_count	BIGINT	YES	NULL	NULL	NULL
created_at	TIMESTAMP	YES	NULL	current_timestamp	NULL
has_primary_key	BOOLEAN	YES	NULL	NULL	NULL
primary_key_columns	VARCHAR[]	YES	NULL	NULL	NULL
scenario_id	INTEGER	NO	PRI	NULL	NULL
table_name	VARCHAR	NO	PRI	NULL	NULL

# Test: _scenario_base_rowids table exists with correct columns
query TTTTTT
SELECT column_name, column_type, "null", "key", "default", extra FROM (DESCRIBE _scenario_base_rowids) ORDER BY 1;
----
base_rowid	BIGINT	NO	PRI	NULL	NULL
scenario_id	INTEGER	NO	PRI	NULL	NULL
table_name	VARCHAR	NO	PRI	NULL	NULL

# Test: _scenario_snapshots table exists with correct columns
query TTTTTT
SELECT column_name, column_type, "null", "key", "default", extra FROM (DESCRIBE _scenario_snapshots) ORDER BY 1;
----
created_at	TIMESTAMP	YES	NULL	current_timestamp	NULL
description	VARCHAR	YES	NULL	NULL	NULL
size_bytes	BIGINT	YES	NULL	NULL	NULL
snapshot_id	INTEGER	NO	PRI	NULL	NULL
snapshot_name	VARCHAR	NO	UNI	NULL	NULL
source_schema	VARCHAR	NO	NULL	NULL	NULL

# Test: _scenario_protocols table exists with correct columns
query TTTTTT
SELECT column_name, column_type, "null", "key", "default", extra FROM (DESCRIBE _scenario_protocols) ORDER BY 1;
----
content	VARCHAR	YES	NULL	NULL	NULL
entity_name	VARCHAR	NO	PRI	NULL	NULL
entity_type	VARCHAR	NO	PRI	NULL	NULL
section	VARCHAR	NO	PRI	NULL	NULL
updated_at	TIMESTAMP	YES	NULL	current_timestamp	NULL

# Test: Tables are initially empty
query I
SELECT COUNT(*) FROM _scenario_registry;
----
0

query I
SELECT COUNT(*) FROM _scenario_tables;
----
0

query I
SELECT COUNT(*) FROM _scenario_snapshots;
----
0

query I
SELECT COUNT(*) FROM _scenario_protocols;
----
0
