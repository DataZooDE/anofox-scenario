# name: test/sql/scenario_read.test
# description: Test merge-on-read views for transparent scenario reads
# group: [anofox_scenario]

require anofox_scenario

# ===== Setup =====

statement ok
CREATE TABLE products (id INTEGER PRIMARY KEY, name VARCHAR, price DECIMAL(10,2));

statement ok
INSERT INTO products VALUES (1, 'Widget', 9.99), (2, 'Gadget', 19.99), (3, 'Thingamajig', 29.99);

# Create scenario
query T
SELECT scenario_create('read_test', 'Testing merge-on-read views');
----
true

# Create delta table (this also creates the merge view)
query T
SELECT delta_create('read_test', 'products');
----
true

# ===== Test 1: Merge view exists and shows base data =====

# Verify view was created
query I
SELECT COUNT(*) FROM information_schema.tables
WHERE table_schema = '_scen_read_test' AND table_name = 'products' AND table_type = 'VIEW';
----
1

# View should show all base rows initially (no deltas)
query ITR
SELECT id, name, price FROM _scen_read_test.products ORDER BY id;
----
1	Widget	9.99
2	Gadget	19.99
3	Thingamajig	29.99

# ===== Test 2: Insert shows in merge view =====

# Insert a new row into delta table
statement ok
INSERT INTO _scen_read_test._delta_products (_op, id, name, price) VALUES ('I', 4, 'NewProduct', 39.99);

# Merge view should show 4 rows now (3 base + 1 insert)
query ITR
SELECT id, name, price FROM _scen_read_test.products ORDER BY id;
----
1	Widget	9.99
2	Gadget	19.99
3	Thingamajig	29.99
4	NewProduct	39.99

# ===== Test 3: Update shows in merge view =====

# Update an existing row (mark in delta as 'U')
statement ok
INSERT INTO _scen_read_test._delta_products (_op, id, name, price) VALUES ('U', 2, 'UpdatedGadget', 24.99);

# Merge view should show updated value for id=2
query ITR
SELECT id, name, price FROM _scen_read_test.products ORDER BY id;
----
1	Widget	9.99
2	UpdatedGadget	24.99
3	Thingamajig	29.99
4	NewProduct	39.99

# ===== Test 4: Delete hides row in merge view =====

# Delete a row (mark in delta as 'D')
statement ok
INSERT INTO _scen_read_test._delta_products (_op, id, name, price) VALUES ('D', 1, 'Widget', 9.99);

# Merge view should show 3 rows (id=1 deleted)
query ITR
SELECT id, name, price FROM _scen_read_test.products ORDER BY id;
----
2	UpdatedGadget	24.99
3	Thingamajig	29.99
4	NewProduct	39.99

# ===== Test 5: Base table remains unchanged =====

# Verify base table still has original data
query ITR
SELECT id, name, price FROM main.products ORDER BY id;
----
1	Widget	9.99
2	Gadget	19.99
3	Thingamajig	29.99

# ===== Test 6: Drop delta table drops view =====

query T
SELECT delta_drop('read_test', 'products');
----
true

# View should be gone
query I
SELECT COUNT(*) FROM information_schema.tables
WHERE table_schema = '_scen_read_test' AND table_name = 'products' AND table_type = 'VIEW';
----
0

# ===== Cleanup =====

query T
SELECT scenario_drop('read_test');
----
true

statement ok
DROP TABLE products;
