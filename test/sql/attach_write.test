# name: test/sql/attach_write.test
# description: Phase 1 WP3: transparent INSERT/UPDATE/DELETE on scenario tables; op-transition matrix
# group: [anofox_scenario]

require anofox_scenario

statement ok
CREATE TABLE forecast (id INTEGER PRIMARY KEY, region VARCHAR, qty INTEGER);

statement ok
INSERT INTO forecast VALUES (1, 'EU', 100), (2, 'US', 200), (3, 'APAC', 300);

statement ok
CALL scenario_create('w', 'write tests');

statement ok
ATTACH 'w' AS s (TYPE scenario);

# --- INSERT (none -> I) --------------------------------------------------------

statement ok
INSERT INTO s.forecast VALUES (10, 'LATAM', 500);

query I
SELECT count(*) FROM s.forecast;
----
4

query ITI
SELECT id, region, qty FROM s.forecast WHERE id = 10;
----
10	LATAM	500

# base is never touched
query I
SELECT count(*) FROM forecast;
----
3

# multi-row insert + INSERT ... SELECT
statement ok
INSERT INTO s.forecast VALUES (11, 'MEA', 50), (12, 'ANZ', 60);

statement ok
INSERT INTO s.forecast SELECT id + 100, region, qty FROM forecast WHERE id = 1;

query I
SELECT count(*) FROM s.forecast;
----
7

query ITI
SELECT id, region, qty FROM s.forecast WHERE id = 101;
----
101	EU	100

# --- UPDATE of a base row (none -> U) -------------------------------------------

statement ok
UPDATE s.forecast SET qty = 220 WHERE id = 2;

query ITI
SELECT id, region, qty FROM s.forecast WHERE id = 2;
----
2	US	220

# base unchanged
query I
SELECT qty FROM forecast WHERE id = 2;
----
200

# row count unchanged by update
query I
SELECT count(*) FROM s.forecast;
----
7

# --- UPDATE of an updated row (U -> U) -------------------------------------------

statement ok
UPDATE s.forecast SET qty = 240 WHERE id = 2;

query I
SELECT qty FROM s.forecast WHERE id = 2;
----
240

# --- UPDATE of an inserted row (I -> I) ------------------------------------------

statement ok
UPDATE s.forecast SET qty = 510 WHERE id = 10;

query ITI
SELECT id, region, qty FROM s.forecast WHERE id = 10;
----
10	LATAM	510

# still absent from base
query I
SELECT count(*) FROM forecast WHERE id = 10;
----
0

# --- multi-row UPDATE across origins ----------------------------------------------

statement ok
UPDATE s.forecast SET qty = qty + 1 WHERE id IN (1, 11);

query I
SELECT qty FROM s.forecast WHERE id = 1;
----
101

query I
SELECT qty FROM s.forecast WHERE id = 11;
----
51

query I
SELECT qty FROM forecast WHERE id = 1;
----
100

# --- DELETE of a base row (none -> D) ----------------------------------------------

statement ok
DELETE FROM s.forecast WHERE id = 3;

query I
SELECT count(*) FROM s.forecast WHERE id = 3;
----
0

query I
SELECT count(*) FROM s.forecast;
----
6

# base unchanged
query I
SELECT count(*) FROM forecast WHERE id = 3;
----
1

# --- DELETE of an inserted row (I -> removed, no trace) -----------------------------

statement ok
DELETE FROM s.forecast WHERE id = 12;

query I
SELECT count(*) FROM s.forecast WHERE id = 12;
----
0

# --- DELETE of an updated row (U -> D) ----------------------------------------------

statement ok
DELETE FROM s.forecast WHERE id = 2;

query I
SELECT count(*) FROM s.forecast WHERE id = 2;
----
0

query I
SELECT count(*) FROM forecast WHERE id = 2;
----
1

# --- INSERT over a tombstone (D -> re-insert) -----------------------------------------

statement ok
INSERT INTO s.forecast VALUES (3, 'APAC2', 330);

query ITI
SELECT id, region, qty FROM s.forecast WHERE id = 3;
----
3	APAC2	330

# base still has the original
query IT
SELECT id, region FROM forecast WHERE id = 3;
----
3	APAC

# --- PK collision errors ---------------------------------------------------------------

# vs base row
statement error
INSERT INTO s.forecast VALUES (1, 'DUP', 0);
----
<REGEX>:.*primary key.*base.*

# vs scenario-inserted row
statement error
INSERT INTO s.forecast VALUES (10, 'DUP', 0);
----
<REGEX>:.*primary key.*scenario.*

# --- transactionality --------------------------------------------------------------------

statement ok
BEGIN;

statement ok
INSERT INTO s.forecast VALUES (77, 'TXN', 1);

# visible inside the transaction
query I
SELECT count(*) FROM s.forecast WHERE id = 77;
----
1

statement ok
ROLLBACK;

query I
SELECT count(*) FROM s.forecast WHERE id = 77;
----
0

# --- TRUNCATE == unfiltered DELETE ----------------------------------------------------------

query I
SELECT count(*) > 0 FROM s.forecast;
----
true

statement ok
TRUNCATE s.forecast;

query I
SELECT count(*) FROM s.forecast;
----
0

# base untouched by truncate
query I
SELECT count(*) FROM forecast;
----
3

statement ok
DETACH s;

statement ok
CALL scenario_drop('w');
