# name: test/sql/attach_txn.test
# description: Phase 1: scenario DML is transactional in the caller's transaction (no side connections)
# group: [anofox_scenario]

require anofox_scenario

statement ok
CREATE TABLE forecast (id INTEGER PRIMARY KEY, qty INTEGER);

statement ok
INSERT INTO forecast VALUES (1, 100), (2, 200);

statement ok
CALL scenario_create('t');

statement ok
ATTACH 't' AS s (TYPE scenario);

# --- rollback undoes scenario DML ----------------------------------------------

statement ok
BEGIN;

statement ok
INSERT INTO s.forecast VALUES (3, 300);

statement ok
UPDATE s.forecast SET qty = 111 WHERE id = 1;

# visible inside the transaction
query I
SELECT count(*) FROM s.forecast;
----
3

query I
SELECT qty FROM s.forecast WHERE id = 1;
----
111

statement ok
ROLLBACK;

query I
SELECT count(*) FROM s.forecast;
----
2

query I
SELECT qty FROM s.forecast WHERE id = 1;
----
100

# --- commit persists scenario DML -------------------------------------------------

statement ok
BEGIN;

statement ok
INSERT INTO s.forecast VALUES (3, 300);

statement ok
DELETE FROM s.forecast WHERE id = 2;

statement ok
COMMIT;

query II
SELECT id, qty FROM s.forecast ORDER BY id;
----
1	100
3	300

# base untouched throughout
query II
SELECT id, qty FROM forecast ORDER BY id;
----
1	100
2	200

# --- multiple scenario statements in one transaction -------------------------------

statement ok
BEGIN;

statement ok
INSERT INTO s.forecast VALUES (4, 400);

statement ok
UPDATE s.forecast SET qty = 401 WHERE id = 4;

statement ok
DELETE FROM s.forecast WHERE id = 4;

statement ok
COMMIT;

query I
SELECT count(*) FROM s.forecast WHERE id = 4;
----
0

# --- mixing host writes and scenario writes in one transaction: clear error ----------
# (single-writer-per-transaction; physically both go to the host, but the
# binder's registration targets differ - documented v1 limitation)

statement ok
BEGIN;

statement ok
INSERT INTO forecast VALUES (9, 900);

statement error
INSERT INTO s.forecast VALUES (10, 1000);
----
<REGEX>:.*single transaction.*

statement ok
ROLLBACK;

statement ok
DETACH s;

statement ok
CALL scenario_drop('t');
