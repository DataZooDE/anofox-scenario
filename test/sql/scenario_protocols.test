# name: test/sql/scenario_protocols.test
# description: Test protocol management operations
# group: [anofox_scenario]

require anofox_scenario

# Setup: Create a scenario for testing protocols
query T
SELECT scenario_create('protocol_test', 'Scenario for protocol testing');
----
true

# Test: Set the "why" protocol for a scenario
query T
SELECT protocol_set_why('protocol_test', 'Testing new pricing strategy for Q2');
----
true

# Verify the protocol was stored
query TTTT
SELECT entity_type, entity_name, section, content FROM _scenario_protocols WHERE entity_name = 'protocol_test';
----
scenario	protocol_test	why	Testing new pricing strategy for Q2

# Test: Update the "why" protocol (should replace existing)
query T
SELECT protocol_set_why('protocol_test', 'Updated reason: Exploring cost reduction options');
----
true

# Verify the protocol was updated (not duplicated)
query I
SELECT COUNT(*) FROM _scenario_protocols WHERE entity_name = 'protocol_test' AND section = 'why';
----
1

# Verify the content was updated
query T
SELECT content FROM _scenario_protocols WHERE entity_name = 'protocol_test' AND section = 'why';
----
Updated reason: Exploring cost reduction options

# Test: protocol_set_why with non-existent scenario
statement error
SELECT protocol_set_why('nonexistent_scenario', 'This should fail');
----
Scenario 'nonexistent_scenario' does not exist

# Test: protocol_set_why with text containing single quotes
query T
SELECT protocol_set_why('protocol_test', 'Testing what''s possible with "special" characters');
----
true

# Verify special characters stored correctly
query T
SELECT content FROM _scenario_protocols WHERE entity_name = 'protocol_test' AND section = 'why';
----
Testing what's possible with "special" characters

# Test: protocol_set_why with empty string
query T
SELECT protocol_set_why('protocol_test', '');
----
true

# Verify empty string stored
query T
SELECT content FROM _scenario_protocols WHERE entity_name = 'protocol_test' AND section = 'why';
----
(empty)

# Test: Set a meaningful why again for final verification
query T
SELECT protocol_set_why('protocol_test', 'Final test: documenting the purpose of this scenario');
----
true

# Verify updated_at is set (just check it's not null)
query I
SELECT COUNT(*) FROM _scenario_protocols WHERE entity_name = 'protocol_test' AND updated_at IS NOT NULL;
----
1

# ===== Test: protocol_log_change =====

# First change entry
query T
SELECT protocol_log_change('protocol_test', 'Increased price by 10% for product A');
----
true

# Verify change was logged
query T
SELECT content FROM _scenario_protocols WHERE entity_name = 'protocol_test' AND section = 'changes';
----
Increased price by 10% for product A

# Second change entry (should append with newline)
query T
SELECT protocol_log_change('protocol_test', 'Added discount for bulk orders');
----
true

# Verify both changes are present (check length increased from first entry)
query I
SELECT LENGTH(content) > 40 FROM _scenario_protocols WHERE entity_name = 'protocol_test' AND section = 'changes';
----
true

# Verify content contains both entries
query I
SELECT content LIKE '%Increased price%' AND content LIKE '%discount for bulk%' FROM _scenario_protocols WHERE entity_name = 'protocol_test' AND section = 'changes';
----
true

# Third change entry
query T
SELECT protocol_log_change('protocol_test', 'Removed discontinued products');
----
true

# Verify all three changes present
query I
SELECT content LIKE '%Increased price%' AND content LIKE '%discount%' AND content LIKE '%discontinued%' FROM _scenario_protocols WHERE entity_name = 'protocol_test' AND section = 'changes';
----
true

# Test: protocol_log_change with special characters
query T
SELECT protocol_log_change('protocol_test', 'Changed "special" item''s price to $9.99');
----
true

# Verify special characters preserved
query I
SELECT LENGTH(content) > 100 FROM _scenario_protocols WHERE entity_name = 'protocol_test' AND section = 'changes';
----
true

# Test: protocol_log_change with non-existent scenario
statement error
SELECT protocol_log_change('nonexistent_scenario', 'This should fail');
----
Scenario 'nonexistent_scenario' does not exist

# Verify 'changes' section is separate from 'why' section
query I
SELECT COUNT(*) FROM _scenario_protocols WHERE entity_name = 'protocol_test';
----
2

query TT
SELECT section, CASE WHEN LENGTH(content) > 0 THEN 'has content' ELSE 'empty' END FROM _scenario_protocols WHERE entity_name = 'protocol_test' ORDER BY section;
----
changes	has content
why	has content

# ===== Test: protocol_add_finding =====

# First finding entry
query T
SELECT protocol_add_finding('protocol_test', 'Revenue increased by 5% with new pricing');
----
true

# Verify finding was logged
query T
SELECT content FROM _scenario_protocols WHERE entity_name = 'protocol_test' AND section = 'findings';
----
Revenue increased by 5% with new pricing

# Second finding entry (should append with newline)
query T
SELECT protocol_add_finding('protocol_test', 'Customer churn remained stable');
----
true

# Verify both findings are present
query I
SELECT content LIKE '%Revenue increased%' AND content LIKE '%churn remained%' FROM _scenario_protocols WHERE entity_name = 'protocol_test' AND section = 'findings';
----
true

# Third finding entry
query T
SELECT protocol_add_finding('protocol_test', 'Competitor analysis shows favorable positioning');
----
true

# Verify all three findings present
query I
SELECT content LIKE '%Revenue%' AND content LIKE '%churn%' AND content LIKE '%Competitor%' FROM _scenario_protocols WHERE entity_name = 'protocol_test' AND section = 'findings';
----
true

# Test: protocol_add_finding with non-existent scenario
statement error
SELECT protocol_add_finding('nonexistent_scenario', 'This should fail');
----
Scenario 'nonexistent_scenario' does not exist

# Verify 'findings' section is separate from 'why' and 'changes' sections
query I
SELECT COUNT(*) FROM _scenario_protocols WHERE entity_name = 'protocol_test';
----
3

query T
SELECT section FROM _scenario_protocols WHERE entity_name = 'protocol_test' ORDER BY section;
----
changes
findings
why

# Cleanup: Drop the test scenario
query T
SELECT scenario_drop('protocol_test');
----
true

# Verify scenario was dropped (protocol entry remains - orphaned but harmless)
query I
SELECT COUNT(*) FROM _scenario_registry WHERE scenario_name = 'protocol_test';
----
0
