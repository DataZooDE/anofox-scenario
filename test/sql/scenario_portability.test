# name: test/sql/scenario_portability.test
# description: Test database portability - scenarios persist across sessions
# group: [anofox_scenario]
#
# Verifies that:
# - Database files with scenarios can be saved and reopened
# - All scenario metadata, delta tables, and protocols persist
# - No external dependencies required for portability

require anofox_scenario

# ============================================================================
# Setup: Create database with complete scenario data
# ============================================================================

# Use a persistent database file
load __TEST_DIR__/portability_test.db

# Create base data
statement ok
CREATE TABLE products (
    id INTEGER PRIMARY KEY,
    name VARCHAR,
    price DECIMAL(10,2),
    category VARCHAR
);

statement ok
INSERT INTO products VALUES
    (1, 'Widget A', 19.99, 'Hardware'),
    (2, 'Widget B', 29.99, 'Hardware'),
    (3, 'Gadget X', 99.99, 'Electronics'),
    (4, 'Gadget Y', 149.99, 'Electronics'),
    (5, 'Service Plan', 9.99, 'Services');

# Create a scenario with full configuration
query T
SELECT scenario_create('pricing_analysis', 'Q1 2026 pricing review');
----
true

# Register table for delta operations
query T
SELECT delta_create('pricing_analysis', 'products');
----
true

# Add some modifications
statement ok
INSERT INTO _scen_pricing_analysis._delta_products (_op, id, name, price, category)
VALUES ('U', 1, 'Widget A', 24.99, 'Hardware'),
       ('U', 2, 'Widget B', 34.99, 'Hardware'),
       ('I', 6, 'New Product', 59.99, 'New Category');

# Add protocol documentation
query T
SELECT protocol_set_why('pricing_analysis', 'Evaluate 25% price increase for hardware category');
----
true

query T
SELECT protocol_log_change('pricing_analysis', 'Increased Widget A price from $19.99 to $24.99');
----
true

query T
SELECT protocol_log_change('pricing_analysis', 'Increased Widget B price from $29.99 to $34.99');
----
true

query T
SELECT protocol_add_finding('pricing_analysis', 'Hardware revenue would increase by $15 per sale');
----
true

query T
SELECT protocol_set_plan('pricing_analysis', 'Phase 1: Hardware only. Phase 2: Review electronics.');
----
true

# Create a snapshot
query T
SELECT snapshot_create('pricing_analysis', 'baseline_snap', 'Baseline before further changes');
----
true

# Verify initial state before restart
query I
SELECT COUNT(*) FROM scenario_list();
----
1

query I
SELECT COUNT(*) FROM _scen_pricing_analysis._delta_products;
----
3

query I
SELECT COUNT(*) FROM protocol_read('pricing_analysis');
----
4

query I
SELECT COUNT(*) FROM snapshot_list();
----
1

# ============================================================================
# Test: Restart database and verify persistence
# ============================================================================

restart

# Verify extension still works after restart
query I
SELECT COUNT(*) FROM scenario_list();
----
1

# Verify scenario metadata persisted
query TTT
SELECT scenario_name, status, description FROM scenario_list();
----
pricing_analysis	active	Q1 2026 pricing review

# Verify delta table data persisted
query I
SELECT COUNT(*) FROM _scen_pricing_analysis._delta_products;
----
3

# Verify merge view works correctly
query I
SELECT COUNT(*) FROM _scen_pricing_analysis.products;
----
6

# Verify specific delta values
query TR
SELECT name, price FROM _scen_pricing_analysis.products WHERE id = 1;
----
Widget A	24.99

query TR
SELECT name, price FROM _scen_pricing_analysis.products WHERE id = 6;
----
New Product	59.99

# Verify protocol data persisted
query I
SELECT COUNT(*) FROM protocol_read('pricing_analysis');
----
4

query TT
SELECT section, content FROM protocol_read('pricing_analysis') WHERE section = 'why';
----
why	Evaluate 25% price increase for hardware category

query TT
SELECT section, content FROM protocol_read('pricing_analysis') WHERE section = 'plan';
----
plan	Phase 1: Hardware only. Phase 2: Review electronics.

# Verify snapshot persisted
query I
SELECT COUNT(*) FROM snapshot_list();
----
1

query TT
SELECT snapshot_name, description FROM snapshot_list();
----
baseline_snap	Baseline before further changes

# ============================================================================
# Test: scenario_compare works after restart
# ============================================================================

query TI
SELECT diff_type, COUNT(*) FROM scenario_compare('pricing_analysis', 'products') GROUP BY diff_type ORDER BY diff_type;
----
added	1
changed	2

# ============================================================================
# Test: scenario_validate works after restart
# ============================================================================

query TT
SELECT table_name, validation_status FROM scenario_validate('pricing_analysis');
----
products	OK

# ============================================================================
# Test: scenario_stats works after restart
# ============================================================================

query II
SELECT table_count, delta_row_count FROM scenario_stats('pricing_analysis');
----
1	3

# ============================================================================
# Test: Can continue modifying after restart
# ============================================================================

# Add more protocol entries
query T
SELECT protocol_add_finding('pricing_analysis', 'Post-restart finding: system stable');
----
true

query I
SELECT COUNT(*) FROM protocol_read('pricing_analysis');
----
4

# Add more delta modifications
statement ok
INSERT INTO _scen_pricing_analysis._delta_products (_op, id, name, price, category)
VALUES ('D', 5, 'Service Plan', 9.99, 'Services');

query I
SELECT COUNT(*) FROM _scen_pricing_analysis.products;
----
5

# ============================================================================
# Test: Second restart to verify continued persistence
# ============================================================================

restart

# Verify all data still present
query I
SELECT COUNT(*) FROM _scen_pricing_analysis._delta_products;
----
4

query I
SELECT COUNT(*) FROM _scen_pricing_analysis.products;
----
5

query I
SELECT COUNT(*) FROM protocol_read('pricing_analysis');
----
4

# ============================================================================
# Test: Create second scenario after restart
# ============================================================================

query T
SELECT scenario_create('post_restart_scenario', 'Created after database restart');
----
true

query T
SELECT delta_create('post_restart_scenario', 'products');
----
true

statement ok
INSERT INTO _scen_post_restart_scenario._delta_products (_op, id, name, price, category)
VALUES ('U', 3, 'Gadget X', 89.99, 'Electronics');

# Verify both scenarios work
query I
SELECT COUNT(*) FROM scenario_list();
----
2

query R
SELECT price FROM _scen_pricing_analysis.products WHERE id = 3;
----
99.99

query R
SELECT price FROM _scen_post_restart_scenario.products WHERE id = 3;
----
89.99

# ============================================================================
# Cleanup
# ============================================================================

query T
SELECT scenario_drop('post_restart_scenario');
----
true

query T
SELECT snapshot_drop('baseline_snap');
----
true

query T
SELECT scenario_drop('pricing_analysis');
----
true

statement ok
DROP TABLE products;

# Verify complete cleanup
query I
SELECT COUNT(*) FROM scenario_list();
----
0

query I
SELECT COUNT(*) FROM snapshot_list();
----
0
