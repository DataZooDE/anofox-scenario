# name: test/sql/scenario_snapshots.test
# description: Test snapshot management operations
# group: [anofox_scenario]

require anofox_scenario

# Setup: Create a scenario to snapshot
statement ok
CREATE TABLE test_data (id INTEGER PRIMARY KEY, value VARCHAR);

statement ok
INSERT INTO test_data VALUES (1, 'hello'), (2, 'world');

query T
SELECT scenario_create('snapshot_test_scenario', 'Scenario for snapshot testing');
----
true

# Test: Create a snapshot with description
query T
SELECT snapshot_create('snapshot_test_scenario', 'test_snapshot', 'A test snapshot');
----
true

# Verify snapshot exists in registry
query TTT
SELECT snapshot_name, source_schema, description FROM _scenario_snapshots WHERE snapshot_name = 'test_snapshot';
----
test_snapshot	_scen_snapshot_test_scenario	A test snapshot

# Test: Cannot create snapshot with existing name
statement error
SELECT snapshot_create('snapshot_test_scenario', 'test_snapshot', 'Duplicate');
----
Snapshot 'test_snapshot' already exists

# Test: Cannot create snapshot for non-existent scenario
statement error
SELECT snapshot_create('nonexistent_scenario', 'new_snapshot', 'Should fail');
----
Scenario 'nonexistent_scenario' does not exist

# Test: Cannot create snapshot with invalid name (spaces)
statement error
SELECT snapshot_create('snapshot_test_scenario', 'invalid name', 'Has spaces');
----
Invalid snapshot name

# Test: Cannot create snapshot with invalid name (special chars)
statement error
SELECT snapshot_create('snapshot_test_scenario', 'invalid-name', 'Has dashes');
----
Invalid snapshot name

# Test: Cannot create snapshot with name too long (>63 chars)
statement error
SELECT snapshot_create('snapshot_test_scenario', 'this_name_is_way_too_long_and_exceeds_the_maximum_allowed_length_of_63_characters', 'Too long');
----
Invalid snapshot name

# Test: Cannot create snapshot with name starting with digit
statement error
SELECT snapshot_create('snapshot_test_scenario', '1invalid', 'Starts with digit');
----
Invalid snapshot name

# Test: Create snapshot without description
query T
SELECT snapshot_create('snapshot_test_scenario', 'simple_snapshot');
----
true

# Verify null description
query T
SELECT description FROM _scenario_snapshots WHERE snapshot_name = 'simple_snapshot';
----
NULL

# Test: Create snapshot with underscore in name
query T
SELECT snapshot_create('snapshot_test_scenario', 'valid_name_2');
----
true

# Verify snapshot was created
query I
SELECT COUNT(*) FROM _scenario_snapshots WHERE snapshot_name = 'valid_name_2';
----
1

# Cleanup: Drop the scenario (snapshots remain as historical records)
query T
SELECT scenario_drop('snapshot_test_scenario');
----
true

# Verify snapshots still exist after scenario drop (they reference source_schema, not scenario_id)
query I
SELECT COUNT(*) FROM _scenario_snapshots WHERE snapshot_name IN ('test_snapshot', 'simple_snapshot', 'valid_name_2');
----
3

# ===== Test: snapshot_list() =====

# snapshot_list should return all snapshots ordered by created_at DESC
query I
SELECT COUNT(*) FROM snapshot_list();
----
3

# Verify snapshot_list returns correct columns
query TT
SELECT snapshot_name, source_schema FROM snapshot_list() ORDER BY snapshot_name;
----
simple_snapshot	_scen_snapshot_test_scenario
test_snapshot	_scen_snapshot_test_scenario
valid_name_2	_scen_snapshot_test_scenario

# Verify description column
query TT
SELECT snapshot_name, description FROM snapshot_list() WHERE snapshot_name = 'test_snapshot';
----
test_snapshot	A test snapshot

# Verify NULL description for simple_snapshot
query TT
SELECT snapshot_name, description FROM snapshot_list() WHERE snapshot_name = 'simple_snapshot';
----
simple_snapshot	NULL

# ===== Test: snapshot_compare() =====

# Create fresh scenario and table for comparison tests
statement ok
CREATE TABLE compare_data (id INTEGER PRIMARY KEY, name VARCHAR, value INTEGER);

statement ok
INSERT INTO compare_data VALUES (1, 'alpha', 100), (2, 'beta', 200), (3, 'gamma', 300);

query T
SELECT scenario_create('compare_scenario', 'Scenario for comparison testing');
----
true

query T
SELECT delta_create('compare_scenario', 'compare_data');
----
true

# Modify some data in the scenario (to have non-empty deltas)
statement ok
INSERT INTO _scen_compare_scenario._delta_compare_data (_op, id, name, value) VALUES ('U', 1, 'alpha_updated', 150);

statement ok
INSERT INTO _scen_compare_scenario._delta_compare_data (_op, id, name, value) VALUES ('I', 4, 'delta', 400);

statement ok
INSERT INTO _scen_compare_scenario._delta_compare_data (_op, id, name, value) VALUES ('D', 3, 'gamma', 300);

# Create snapshot capturing this state
query T
SELECT snapshot_create('compare_scenario', 'compare_snapshot', 'Snapshot with modifications');
----
true

# Verify snapshot schema was created
query I
SELECT COUNT(*) FROM information_schema.schemata WHERE schema_name = '_snap_compare_snapshot';
----
1

# Verify materialized table was copied (merged view at snapshot time)
query I
SELECT COUNT(*) FROM information_schema.tables WHERE table_schema = '_snap_compare_snapshot' AND table_name = 'compare_data';
----
1

# Verify snapshot data (scenario's merged view: id=1 updated, id=4 inserted, id=3 deleted)
query I
SELECT COUNT(*) FROM _snap_compare_snapshot.compare_data;
----
3

# Now modify main table (simulating changes since snapshot)
statement ok
UPDATE compare_data SET name = 'alpha_main' WHERE id = 1;

statement ok
INSERT INTO compare_data VALUES (5, 'epsilon', 500);

# snapshot_compare should show differences between snapshot state and current main
# Snapshot state: id=1 (alpha_updated, 150), id=2 (beta, 200), id=4 (delta, 400)
# Main state: id=1 (alpha_main, 100), id=2 (beta, 200), id=3 (gamma, 300), id=5 (epsilon, 500)

# Find added rows (in main but not in snapshot): id=3 (was deleted in snapshot), id=5 (new)
query IT
SELECT diff_type, id FROM snapshot_compare('compare_snapshot', 'compare_data') WHERE diff_type = 'added' ORDER BY id;
----
added	3
added	5

# Find removed rows (in snapshot but not in main): id=4 (was only in scenario)
query IT
SELECT diff_type, id FROM snapshot_compare('compare_snapshot', 'compare_data') WHERE diff_type = 'removed' ORDER BY id;
----
removed	4

# Find changed rows: id=1 has different name and value
query ITT
SELECT diff_type, id, column_name FROM snapshot_compare('compare_snapshot', 'compare_data') WHERE diff_type = 'changed' ORDER BY id, column_name;
----
changed	1	name
changed	1	value

# Verify old and new values for name change
query ITTTT
SELECT diff_type, id, column_name, old_value, new_value FROM snapshot_compare('compare_snapshot', 'compare_data') WHERE id = 1 AND column_name = 'name';
----
changed	1	name	alpha_updated	alpha_main

# Test: Cannot compare non-existent snapshot
statement error
SELECT * FROM snapshot_compare('nonexistent_snapshot', 'compare_data');
----
Snapshot 'nonexistent_snapshot' does not exist

# Test: Cannot compare non-existent table
statement error
SELECT * FROM snapshot_compare('compare_snapshot', 'nonexistent_table');
----
not found

# Cleanup
query T
SELECT scenario_drop('compare_scenario');
----
true

statement ok
DROP TABLE compare_data;

# ===== Test: scenario_from_snapshot() =====

# First clean up compare_snapshot for reuse
# (Don't drop _snap_compare_snapshot yet - we'll use it)

# Create a scenario from the existing compare_snapshot
query T
SELECT scenario_from_snapshot('compare_snapshot', 'from_snap_scenario', 'Scenario created from snapshot');
----
true

# Verify scenario was created
query I
SELECT COUNT(*) FROM scenario_list() WHERE scenario_name = 'from_snap_scenario';
----
1

# Verify base_schema is the snapshot schema
query T
SELECT base_schema FROM _scenario_registry WHERE scenario_name = 'from_snap_scenario';
----
_snap_compare_snapshot

# Verify scenario schema was created
query I
SELECT COUNT(*) FROM information_schema.schemata WHERE schema_name = '_scen_from_snap_scenario';
----
1

# Verify delta table was created for the compare_data table
query I
SELECT COUNT(*) FROM information_schema.tables WHERE table_schema = '_scen_from_snap_scenario' AND table_name = '_delta_compare_data';
----
1

# Verify merge view was created
query I
SELECT COUNT(*) FROM information_schema.tables WHERE table_schema = '_scen_from_snap_scenario' AND table_name = 'compare_data';
----
1

# Verify the scenario sees snapshot data as base (not current main)
# Snapshot had: id=1 (alpha_updated, 150), id=2 (beta, 200), id=4 (delta, 400)
query I
SELECT COUNT(*) FROM _scen_from_snap_scenario.compare_data;
----
3

# Verify id=1 shows snapshot values (not main values)
query TI
SELECT name, value FROM _scen_from_snap_scenario.compare_data WHERE id = 1;
----
alpha_updated	150

# Verify id=4 is visible (was only in snapshot, not in main)
query TI
SELECT name, value FROM _scen_from_snap_scenario.compare_data WHERE id = 4;
----
delta	400

# Verify id=3 and id=5 are NOT visible (they are in main but not in snapshot)
query I
SELECT COUNT(*) FROM _scen_from_snap_scenario.compare_data WHERE id IN (3, 5);
----
0

# Test: Can modify the new scenario without affecting snapshot
statement ok
INSERT INTO _scen_from_snap_scenario._delta_compare_data (_op, id, name, value) VALUES ('I', 5, 'new_in_scen', 500);

# New row should be visible in scenario
query TI
SELECT name, value FROM _scen_from_snap_scenario.compare_data WHERE id = 5;
----
new_in_scen	500

# But snapshot should be unchanged (still only 3 rows)
query I
SELECT COUNT(*) FROM _snap_compare_snapshot.compare_data;
----
3

# Test: Cannot create scenario from non-existent snapshot
statement error
SELECT scenario_from_snapshot('nonexistent_snap', 'new_scenario');
----
Snapshot 'nonexistent_snap' does not exist

# Test: Cannot create scenario with existing name
statement error
SELECT scenario_from_snapshot('compare_snapshot', 'from_snap_scenario');
----
Scenario 'from_snap_scenario' already exists

# Cleanup
query T
SELECT scenario_drop('from_snap_scenario');
----
true

# Drop snapshot schema manually for cleanup
statement ok
DROP SCHEMA _snap_compare_snapshot CASCADE;

# Test empty snapshot_list after cleanup (at end of file)

# Cleanup: Delete snapshots for clean state (direct table manipulation for test cleanup)
statement ok
DELETE FROM _scenario_snapshots;

# Verify empty list
query I
SELECT COUNT(*) FROM snapshot_list();
----
0

statement ok
DROP TABLE test_data;
