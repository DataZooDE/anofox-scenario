# name: test/sql/scenario_merge_materialized.test
# description: Merge-back for materialized scenarios: 3-way conflicts via the frozen copy
# group: [anofox_scenario]

require anofox_scenario

statement ok
CREATE TABLE inventory (sku INTEGER PRIMARY KEY, warehouse VARCHAR, stock INTEGER);

statement ok
INSERT INTO inventory VALUES (1, 'BER', 100), (2, 'MUC', 200), (3, 'HAM', 300), (4, 'FRA', 400);

statement ok
CALL scenario_create('replan', 'inventory replan', mode := 'materialized');

statement ok
ATTACH 'replan' AS r (TYPE scenario);

# scenario: restock sku 1, delete sku 3, add sku 10
statement ok
UPDATE r.inventory SET stock = 150 WHERE sku = 1;

statement ok
DELETE FROM r.inventory WHERE sku = 3;

statement ok
INSERT INTO r.inventory VALUES (10, 'STR', 50);

# meanwhile the live base changes: sku 2 drifts (untouched by the scenario -
# no conflict), sku 4 vanishes (also untouched - no conflict)
statement ok
UPDATE inventory SET stock = 999 WHERE sku = 2;

statement ok
DELETE FROM inventory WHERE sku = 4;

# clean merge: scenario changes apply, unrelated base drift survives
query III
SELECT tables_changed, rows_applied, conflicts_resolved FROM scenario_merge('replan');
----
1	3	0

query ITI rowsort
SELECT sku, warehouse, stock FROM inventory;
----
1	BER	150
10	STR	50
2	MUC	999

query TT
SELECT mode, frozen FROM scenario_list() WHERE name = 'replan';
----
materialized	true

# --- drift on a touched row is a 3-way conflict --------------------------------------

statement ok
CREATE TABLE prices (sku INTEGER PRIMARY KEY, price DECIMAL(8,2));

statement ok
INSERT INTO prices VALUES (1, 9.99), (2, 19.99);

statement ok
CALL scenario_create('reprice', mode := 'materialized');

statement ok
ATTACH 'reprice' AS p (TYPE scenario);

statement ok
UPDATE p.prices SET price = 11.00 WHERE sku = 1;

# the base moves the same row after the snapshot: genuine 3-way conflict
statement ok
UPDATE prices SET price = 8.49 WHERE sku = 1;

statement error
SELECT * FROM scenario_merge('reprice');
----
<REGEX>:.*base changed underneath.*

# preview flags it too
query TTTT
SELECT table_name, key, action, conflict FROM scenario_merge_preview('reprice');
----
prices	1	update	true

# theirs: base wins, delta row dropped
query III
SELECT tables_changed, rows_applied, conflicts_resolved FROM scenario_merge('reprice', on_conflict := 'theirs');
----
0	0	1

query T
SELECT price::VARCHAR FROM prices WHERE sku = 1;
----
8.49

# ours: scenario wins over base drift
statement ok
CALL scenario_create('reprice2', mode := 'materialized');

statement ok
ATTACH 'reprice2' AS p2 (TYPE scenario);

statement ok
UPDATE p2.prices SET price = 12.00 WHERE sku = 2;

statement ok
UPDATE prices SET price = 17.99 WHERE sku = 2;

query III
SELECT tables_changed, rows_applied, conflicts_resolved FROM scenario_merge('reprice2', on_conflict := 'ours');
----
1	1	1

query T
SELECT price::VARCHAR FROM prices WHERE sku = 2;
----
12.00

# --- cleanup -------------------------------------------------------------------------

statement ok
DETACH r;

statement ok
DETACH p;

statement ok
DETACH p2;

statement ok
CALL scenario_drop('replan');

statement ok
CALL scenario_drop('reprice');

statement ok
CALL scenario_drop('reprice2');
