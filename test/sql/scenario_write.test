# name: test/sql/scenario_write.test
# description: Test delta table structure and operations
# group: [anofox_scenario]

require anofox_scenario

# ===== Delta Table Structure Tests (Task 2.0) =====

# Setup: Create base tables
statement ok
CREATE TABLE products (id INTEGER PRIMARY KEY, name VARCHAR, price DECIMAL(10,2));

statement ok
INSERT INTO products VALUES (1, 'Widget', 9.99), (2, 'Gadget', 19.99), (3, 'Thingamajig', 29.99);

statement ok
CREATE TABLE orders (order_id INTEGER PRIMARY KEY, product_id INTEGER, qty INTEGER);

statement ok
INSERT INTO orders VALUES (100, 1, 5), (101, 2, 3);

statement ok
CREATE TABLE no_pk_table (col1 VARCHAR, col2 INTEGER);

statement ok
INSERT INTO no_pk_table VALUES ('a', 1), ('b', 2);

# Create scenario
query T
SELECT scenario_create('delta_test', 'Testing delta table creation');
----
true

# Test: Create delta table for products
query T
SELECT delta_create('delta_test', 'products');
----
true

# Verify delta table was created
query I
SELECT COUNT(*) FROM information_schema.tables WHERE table_schema = '_scen_delta_test' AND table_name = '_delta_products';
----
1

# Verify delta table has correct columns (_op, _ts, _version + base columns)
query TTT
SELECT column_name, data_type, is_nullable FROM information_schema.columns
WHERE table_schema = '_scen_delta_test' AND table_name = '_delta_products'
ORDER BY ordinal_position;
----
_op	VARCHAR	NO
_ts	TIMESTAMP	YES
_version	INTEGER	YES
id	INTEGER	NO
name	VARCHAR	YES
price	DECIMAL(10,2)	YES

# Test: Cannot create delta table twice
statement error
SELECT delta_create('delta_test', 'products');
----
Delta table for 'products' already exists in scenario 'delta_test'

# Test: Create delta table for orders
query T
SELECT delta_create('delta_test', 'orders');
----
true

# Test: Create delta table for table without primary key
query T
SELECT delta_create('delta_test', 'no_pk_table');
----
true

# Verify no_pk_table delta has no PRIMARY KEY constraint (since base has none)
query I
SELECT COUNT(*) FROM information_schema.table_constraints
WHERE table_schema = '_scen_delta_test' AND table_name = '_delta_no_pk_table' AND constraint_type = 'PRIMARY KEY';
----
0

# Test: Error for non-existent scenario
statement error
SELECT delta_create('nonexistent', 'products');
----
Scenario 'nonexistent' does not exist

# Test: Error for non-existent table
statement error
SELECT delta_create('delta_test', 'nonexistent_table');
----
Base table 'nonexistent_table' not found in main schema

# Test: Delta table respects CHECK constraint on _op
query T
SELECT delta_drop('delta_test', 'products');
----
true

query T
SELECT delta_create('delta_test', 'products');
----
true

# Insert valid operation
statement ok
INSERT INTO _scen_delta_test._delta_products (_op, id, name, price) VALUES ('I', 4, 'New Item', 39.99);

# Verify insert
query ITTR
SELECT id, name, price, _op FROM _scen_delta_test._delta_products;
----
4	New Item	39.99	I

# Test: Invalid _op value should fail
statement error
INSERT INTO _scen_delta_test._delta_products (_op, id, name, price) VALUES ('X', 5, 'Bad', 0.00);
----
CHECK

# Test: delta_drop function
query T
SELECT delta_drop('delta_test', 'products');
----
true

# Verify delta table was dropped
query I
SELECT COUNT(*) FROM information_schema.tables WHERE table_schema = '_scen_delta_test' AND table_name = '_delta_products';
----
0

# Test: Cannot drop non-existent delta table
statement error
SELECT delta_drop('delta_test', 'products');
----
Delta table for 'products' does not exist in scenario 'delta_test'

# ===== Test delta_row_count in scenario_stats =====

# Create fresh delta table and insert some rows
query T
SELECT delta_create('delta_test', 'products');
----
true

statement ok
INSERT INTO _scen_delta_test._delta_products (_op, id, name, price) VALUES ('I', 10, 'Item1', 10.00);

statement ok
INSERT INTO _scen_delta_test._delta_products (_op, id, name, price) VALUES ('I', 11, 'Item2', 20.00);

statement ok
INSERT INTO _scen_delta_test._delta_products (_op, id, name, price) VALUES ('I', 12, 'Item3', 30.00);

# Verify scenario_stats now returns correct delta_row_count
query I
SELECT delta_row_count FROM scenario_stats('delta_test');
----
3

# Add more delta tables with rows (orders delta already exists from earlier, need to drop first)
query T
SELECT delta_drop('delta_test', 'orders');
----
true

query T
SELECT delta_create('delta_test', 'orders');
----
true

statement ok
INSERT INTO _scen_delta_test._delta_orders (_op, order_id, product_id, qty) VALUES ('I', 200, 10, 1);

# Verify total delta_row_count includes all delta tables
query I
SELECT delta_row_count FROM scenario_stats('delta_test');
----
4

# Cleanup
query T
SELECT scenario_drop('delta_test');
----
true

statement ok
DROP TABLE products;

statement ok
DROP TABLE orders;

statement ok
DROP TABLE no_pk_table;

# ===== Transparent Write Operation Tests (Tasks 2.3, 2.4, 2.5) =====

# Setup for write tests
statement ok
CREATE TABLE inventory (sku VARCHAR PRIMARY KEY, qty INTEGER, warehouse VARCHAR);

statement ok
INSERT INTO inventory VALUES ('SKU001', 100, 'NYC'), ('SKU002', 50, 'LA'), ('SKU003', 75, 'CHI');

query T
SELECT scenario_create('write_ops_test', 'Testing transparent write operations');
----
true

query T
SELECT delta_create('write_ops_test', 'inventory');
----
true

# ===== Test INSERT Operation (Task 2.3) =====

# Insert new rows into delta table
statement ok
INSERT INTO _scen_write_ops_test._delta_inventory (_op, sku, qty, warehouse) VALUES ('I', 'SKU004', 200, 'SEA');

statement ok
INSERT INTO _scen_write_ops_test._delta_inventory (_op, sku, qty, warehouse) VALUES ('I', 'SKU005', 150, 'DEN');

# Verify inserts show in merge view
query TIT
SELECT sku, qty, warehouse FROM _scen_write_ops_test.inventory WHERE sku IN ('SKU004', 'SKU005') ORDER BY sku;
----
SKU004	200	SEA
SKU005	150	DEN

# Total should be 5 rows now
query I
SELECT COUNT(*) FROM _scen_write_ops_test.inventory;
----
5

# ===== Test UPDATE Operation (Task 2.4) =====

# Update existing row (use INSERT OR REPLACE to handle PK constraint)
statement ok
INSERT OR REPLACE INTO _scen_write_ops_test._delta_inventory (_op, sku, qty, warehouse) VALUES ('U', 'SKU001', 120, 'NYC');

# Verify update shows in merge view
query TIT
SELECT sku, qty, warehouse FROM _scen_write_ops_test.inventory WHERE sku = 'SKU001';
----
SKU001	120	NYC

# Update a row we just inserted
statement ok
INSERT OR REPLACE INTO _scen_write_ops_test._delta_inventory (_op, sku, qty, warehouse) VALUES ('U', 'SKU004', 250, 'SEA');

query TIT
SELECT sku, qty, warehouse FROM _scen_write_ops_test.inventory WHERE sku = 'SKU004';
----
SKU004	250	SEA

# ===== Test DELETE Operation (Task 2.5) =====

# Delete a base row
statement ok
INSERT OR REPLACE INTO _scen_write_ops_test._delta_inventory (_op, sku, qty, warehouse) VALUES ('D', 'SKU002', 50, 'LA');

# Row should not appear in merge view
query I
SELECT COUNT(*) FROM _scen_write_ops_test.inventory WHERE sku = 'SKU002';
----
0

# Total should be 4 rows now (5 - 1 deleted)
query I
SELECT COUNT(*) FROM _scen_write_ops_test.inventory;
----
4

# Delete an inserted row
statement ok
INSERT OR REPLACE INTO _scen_write_ops_test._delta_inventory (_op, sku, qty, warehouse) VALUES ('D', 'SKU005', 150, 'DEN');

query I
SELECT COUNT(*) FROM _scen_write_ops_test.inventory;
----
3

# ===== Test Update then Delete (complex scenario) =====

# Update SKU003
statement ok
INSERT OR REPLACE INTO _scen_write_ops_test._delta_inventory (_op, sku, qty, warehouse) VALUES ('U', 'SKU003', 100, 'CHI');

# Then delete it
statement ok
INSERT OR REPLACE INTO _scen_write_ops_test._delta_inventory (_op, sku, qty, warehouse) VALUES ('D', 'SKU003', 100, 'CHI');

# Should not appear
query I
SELECT COUNT(*) FROM _scen_write_ops_test.inventory WHERE sku = 'SKU003';
----
0

# ===== Verify base table unchanged =====

query TIT
SELECT sku, qty, warehouse FROM main.inventory ORDER BY sku;
----
SKU001	100	NYC
SKU002	50	LA
SKU003	75	CHI

# Cleanup
query T
SELECT scenario_drop('write_ops_test');
----
true

statement ok
DROP TABLE inventory;

# ===== Test scenario_write Function (Task 2.2 fallback) =====

statement ok
CREATE TABLE items (item_id INTEGER PRIMARY KEY, item_name VARCHAR, quantity INTEGER);

statement ok
INSERT INTO items VALUES (1, 'Alpha', 10), (2, 'Beta', 20), (3, 'Gamma', 30);

query T
SELECT scenario_create('write_func_test', 'Testing scenario_write function');
----
true

query T
SELECT delta_create('write_func_test', 'items');
----
true

# Test INSERT using scenario_write
query T
SELECT scenario_write('write_func_test', 'items', 'I', {item_id: 4, item_name: 'Delta', quantity: 40});
----
true

# Verify insert
query ITI
SELECT item_id, item_name, quantity FROM _scen_write_func_test.items WHERE item_id = 4;
----
4	Delta	40

# Test UPDATE using scenario_write
query T
SELECT scenario_write('write_func_test', 'items', 'U', {item_id: 2, item_name: 'Beta Updated', quantity: 25});
----
true

# Verify update
query ITI
SELECT item_id, item_name, quantity FROM _scen_write_func_test.items WHERE item_id = 2;
----
2	Beta Updated	25

# Test DELETE using scenario_write
query T
SELECT scenario_write('write_func_test', 'items', 'D', {item_id: 1, item_name: 'Alpha', quantity: 10});
----
true

# Verify delete (row should not appear)
query I
SELECT COUNT(*) FROM _scen_write_func_test.items WHERE item_id = 1;
----
0

# Verify total count (should be 3: original 3 - 1 deleted + 1 inserted)
query I
SELECT COUNT(*) FROM _scen_write_func_test.items;
----
3

# Verify base table unchanged
query ITI
SELECT item_id, item_name, quantity FROM main.items ORDER BY item_id;
----
1	Alpha	10
2	Beta	20
3	Gamma	30

# Test error: invalid operation
statement error
SELECT scenario_write('write_func_test', 'items', 'X', {item_id: 5, item_name: 'Error', quantity: 0});
----
must be 'I'

# Test error: non-existent scenario
statement error
SELECT scenario_write('nonexistent', 'items', 'I', {item_id: 5, item_name: 'Error', quantity: 0});
----
does not exist

# Cleanup
query T
SELECT scenario_drop('write_func_test');
----
true

statement ok
DROP TABLE items;
