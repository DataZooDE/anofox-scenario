# name: test/sql/scenario_concurrent.test
# description: Test concurrent read safety for scenarios
# group: [anofox_scenario]
#
# Validates that multiple sessions can read scenarios concurrently.
# DuckDB enforces single-writer, but multiple readers should work safely.

require anofox_scenario

# ============================================================================
# Setup: Create test data and scenarios
# ============================================================================

statement ok
CREATE TABLE concurrent_data (
    id INTEGER PRIMARY KEY,
    category VARCHAR,
    value DOUBLE
);

# Generate test data
statement ok
INSERT INTO concurrent_data
SELECT i, CASE (i % 3) WHEN 0 THEN 'A' WHEN 1 THEN 'B' ELSE 'C' END, i * 1.5
FROM generate_series(1, 1000) t(i);

# Verify base data
query I
SELECT COUNT(*) FROM concurrent_data;
----
1000

# Create first scenario with modifications
query T
SELECT scenario_create('concurrent_scenario_1', 'Test concurrent reads');
----
true

query T
SELECT delta_create('concurrent_scenario_1', 'concurrent_data');
----
true

# Add some modifications to scenario 1
statement ok
INSERT INTO _scen_concurrent_scenario_1._delta_concurrent_data (_op, id, category, value)
SELECT 'U', id, 'UPDATED', value * 2.0 FROM concurrent_data WHERE id <= 100;

# Create second scenario with different modifications
query T
SELECT scenario_create('concurrent_scenario_2', 'Second concurrent test');
----
true

query T
SELECT delta_create('concurrent_scenario_2', 'concurrent_data');
----
true

# Add modifications to scenario 2
statement ok
INSERT INTO _scen_concurrent_scenario_2._delta_concurrent_data (_op, id, category, value)
SELECT 'U', id, 'ALT', value * 0.5 FROM concurrent_data WHERE id > 900;

# ============================================================================
# Test 1: Concurrent reads from same scenario
# ============================================================================
# Multiple threads read from the same scenario view simultaneously

concurrentloop threadid 0 5

query I
SELECT COUNT(*) FROM _scen_concurrent_scenario_1.concurrent_data;
----
1000

query I
SELECT COUNT(*) FROM _scen_concurrent_scenario_1.concurrent_data WHERE category = 'UPDATED';
----
100

endloop

# ============================================================================
# Test 2: Concurrent reads from different scenarios
# ============================================================================
# Threads read from different scenarios simultaneously

concurrentloop threadid 0 5

query I
SELECT COUNT(*) FROM _scen_concurrent_scenario_1.concurrent_data WHERE category = 'UPDATED';
----
100

query I
SELECT COUNT(*) FROM _scen_concurrent_scenario_2.concurrent_data WHERE category = 'ALT';
----
100

endloop

# ============================================================================
# Test 3: Concurrent scenario metadata reads
# ============================================================================
# Multiple threads query scenario_list and other metadata functions

concurrentloop threadid 0 5

query I
SELECT COUNT(*) FROM scenario_list() WHERE scenario_name LIKE 'concurrent_scenario_%';
----
2

query I
SELECT COUNT(*) FROM scenario_list();
----
2

endloop

# ============================================================================
# Test 4: Concurrent scenario_compare operations
# ============================================================================
# Multiple threads run comparison queries simultaneously

concurrentloop threadid 0 5

query I
SELECT COUNT(*) FROM scenario_compare('concurrent_scenario_1', 'concurrent_data') WHERE diff_type = 'changed';
----
200

endloop

# ============================================================================
# Test 5: Mixed concurrent operations
# ============================================================================
# Different threads perform different read operations

concurrentloop threadid 0 10

# Read from scenario view
query R
SELECT SUM(value) FROM _scen_concurrent_scenario_1.concurrent_data WHERE id <= 10;
----
165.0

# Read from base table
query R
SELECT SUM(value) FROM concurrent_data WHERE id <= 10;
----
82.5

# Query metadata
query I
SELECT COUNT(*) FROM scenario_list();
----
2

endloop

# ============================================================================
# Test 6: Concurrent aggregation queries
# ============================================================================
# Stress test with aggregation across scenario views

concurrentloop threadid 0 5

query IR
SELECT category, SUM(value) FROM _scen_concurrent_scenario_1.concurrent_data GROUP BY category ORDER BY category LIMIT 1;
----
A	247725.0

query I
SELECT COUNT(DISTINCT category) FROM _scen_concurrent_scenario_1.concurrent_data;
----
4

endloop

# ============================================================================
# Test 7: Concurrent protocol reads
# ============================================================================
# Set up protocols and read them concurrently

query T
SELECT protocol_set_why('concurrent_scenario_1', 'Testing concurrent protocol access');
----
true

query T
SELECT protocol_log_change('concurrent_scenario_1', 'Modified 100 rows');
----
true

concurrentloop threadid 0 5

query I
SELECT COUNT(*) FROM protocol_read('concurrent_scenario_1');
----
2

endloop

# ============================================================================
# Cleanup
# ============================================================================

query T
SELECT scenario_drop('concurrent_scenario_2');
----
true

query T
SELECT scenario_drop('concurrent_scenario_1');
----
true

statement ok
DROP TABLE concurrent_data;

# Verify cleanup
query I
SELECT COUNT(*) FROM scenario_list();
----
0
