# name: test/sql/scenario_security.test
# description: Test SQL injection prevention and input validation
# group: [anofox_scenario]

require anofox_scenario

# Test 1: Scenario name with SQL metacharacters should fail validation
statement error
SELECT scenario_create('test''; DROP TABLE --', 'injection attempt');
----
Invalid scenario name

# Test 2: Scenario name with quotes should fail validation
statement error
SELECT scenario_create('test"name', 'double quote');
----
Invalid scenario name

# Test 3: Scenario name with spaces should fail validation
statement error
SELECT scenario_create('test name', 'has space');
----
Invalid scenario name

# Test 4: Scenario name starting with digit should fail validation
statement error
SELECT scenario_create('1test', 'starts with digit');
----
Invalid scenario name

# Test 5: Description with quotes should be properly escaped (should succeed)
statement ok
SELECT scenario_create('desc_test', 'Description with ''quotes'' and "double quotes"');

# Verify the description was stored correctly
query T
SELECT description FROM scenario_list() WHERE scenario_name = 'desc_test';
----
Description with 'quotes' and "double quotes"

# Cleanup
statement ok
SELECT scenario_drop('desc_test');

# Test 6: Description with potential SQL injection should be safely escaped
statement ok
SELECT scenario_create('inject_test', 'value''); DROP TABLE _scenario_registry; --');

# Verify the scenario was created (proving injection didn't work)
query I
SELECT COUNT(*) FROM scenario_list() WHERE scenario_name = 'inject_test';
----
1

# Verify the registry table still exists
query I
SELECT COUNT(*) FROM _scenario_registry WHERE scenario_name = 'inject_test';
----
1

# Cleanup
statement ok
SELECT scenario_drop('inject_test');

# Test 7: Empty scenario name should fail
statement error
SELECT scenario_create('', 'empty name');
----
Invalid scenario name

# Test 8: Very long scenario name (64+ chars) should fail
statement error
SELECT scenario_create('this_is_a_very_long_scenario_name_that_exceeds_sixty_three_characters_limit', 'too long');
----
Invalid scenario name

# Test 9: delta_create with invalid table name should fail
statement ok
SELECT scenario_create('delta_sec_test', 'for delta tests');

statement error
SELECT delta_create('delta_sec_test', 'table''; DROP TABLE --');
----
Invalid table name

statement error
SELECT delta_create('delta_sec_test', 'table name');
----
Invalid table name

statement error
SELECT delta_create('delta_sec_test', '1table');
----
Invalid table name

# Cleanup
statement ok
SELECT scenario_drop('delta_sec_test');

# Test 10: scenario_branch with injection in description should be safe
statement ok
SELECT scenario_create('branch_base', 'base for branching');

statement ok
SELECT scenario_branch('branch_base', 'branch_child', 'Description with '' and potential injection''; --');

# Verify branch was created
query I
SELECT COUNT(*) FROM scenario_list() WHERE scenario_name = 'branch_child';
----
1

# Cleanup
statement ok
SELECT scenario_drop('branch_child');

statement ok
SELECT scenario_drop('branch_base');

# ============================================
# Bind-time error tests (TEST-2)
# ============================================

# Test: NULL scenario_name at bind time should fail
statement error
SELECT scenario_create(NULL);
----
scenario_create requires

# Test: NULL in scenario_drop should fail
statement error
SELECT scenario_drop(NULL);
----
scenario_drop requires

# Test: NULL in scenario_archive should fail
statement error
SELECT scenario_archive(NULL);
----
scenario_archive requires

# Test: NULL in delta_create should fail
statement error
SELECT delta_create(NULL, 'table');
----
delta_create requires

# Test: scenario_stats with non-existent scenario should fail
statement error
SELECT * FROM scenario_stats('nonexistent_scenario_xyz');
----
does not exist
