# name: test/sql/scenario_ducklake_base.test
# description: Phase 4: scenarios over a DuckLake base with creation-time snapshot isolation
# group: [anofox_scenario]

require anofox_scenario

require parquet

# needs the ducklake extension installed for the running duckdb version;
# run with DUCKLAKE_TESTS=1 (release build - see phase 4 spike notes)
require-env DUCKLAKE_TESTS

statement ok
LOAD ducklake;

statement ok
ATTACH 'ducklake:__TEST_DIR__/lake_meta.ducklake' AS lake (DATA_PATH '__TEST_DIR__/lake_data');

statement ok
CREATE TABLE lake.forecast (id INTEGER, region VARCHAR, qty INTEGER);

statement ok
INSERT INTO lake.forecast VALUES (1, 'EU', 100), (2, 'US', 200), (3, 'APAC', 300);

statement ok
CALL scenario_create('lakescen', 'over a ducklake', base := 'lake', key_columns := MAP {'forecast': ['id']});

statement ok
ATTACH 'lakescen' AS s (TYPE scenario);

# reads flow through the ducklake scan
query ITI
SELECT id, region, qty FROM s.forecast ORDER BY id;
----
1	EU	100
2	US	200
3	APAC	300

# --- REAL snapshot isolation: base churn after creation is INVISIBLE -------------

statement ok
INSERT INTO lake.forecast VALUES (4, 'LATAM', 400);

statement ok
UPDATE lake.forecast SET qty = 999 WHERE id = 1;

statement ok
DELETE FROM lake.forecast WHERE id = 3;

# the lake moved on...
query I
SELECT count(*) FROM lake.forecast;
----
3

# ...but the scenario still sees creation time
query ITI
SELECT id, region, qty FROM s.forecast ORDER BY id;
----
1	EU	100
2	US	200
3	APAC	300

# --- scenario inserts overlay the pinned base (deltas live in the host) ------------

statement ok
INSERT INTO s.forecast VALUES (10, 'MEA', 50);

query I
SELECT count(*) FROM s.forecast;
----
4

query I
SELECT count(*) FROM lake.forecast WHERE id = 10;
----
0

# key_columns declared at create unlock the full DML surface on the lake
statement ok
UPDATE s.forecast SET qty = 111 WHERE id = 1;

statement ok
DELETE FROM s.forecast WHERE id = 2;

# merged view: pinned base + scenario edits (still ignoring all lake churn)
query ITI
SELECT id, region, qty FROM s.forecast ORDER BY id;
----
1	EU	111
3	APAC	300
10	MEA	50

# diff reads the declared-key changelog
query ITT
SELECT id, change_type, new_value FROM scenario_diff('lakescen', 'forecast') ORDER BY id;
----
1	modified	111
2	removed	NULL
10	added	NULL

# merge-back into a foreign catalog is refused (single-writer rule)
statement error
SELECT * FROM scenario_merge('lakescen');
----
<REGEX>:.*another catalog.*

# --- cleanup ------------------------------------------------------------------------

statement ok
DETACH s;

statement ok
CALL scenario_drop('lakescen');

statement ok
DETACH lake;
