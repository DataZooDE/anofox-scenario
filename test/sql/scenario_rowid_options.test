# name: test/sql/scenario_rowid_options.test
# description: Test deferred/skipped rowid capture options
# group: [anofox_scenario]
#
# Tests the capture_rowids parameter for scenario_create:
# - Default behavior captures rowids
# - capture_rowids := false skips rowid capture
# - scenario_validate handles missing rowids gracefully

require anofox_scenario

# ============================================================================
# Setup
# ============================================================================

statement ok
CREATE TABLE rowid_test (id INTEGER PRIMARY KEY, value VARCHAR);

statement ok
INSERT INTO rowid_test VALUES (1, 'one'), (2, 'two'), (3, 'three');

# ============================================================================
# Test 1: Default behavior (capture_rowids = true)
# ============================================================================

query T
SELECT scenario_create('with_rowids', 'Scenario with rowid capture');
----
true

# Rowids should be captured
query I
SELECT COUNT(*) FROM _scenario_base_rowids WHERE scenario_id = (
    SELECT scenario_id FROM _scenario_registry WHERE scenario_name = 'with_rowids'
);
----
3

# scenario_validate should work normally
query TTII
SELECT table_name, validation_status, captured_row_count, current_row_count
FROM scenario_validate('with_rowids');
----
rowid_test	OK	3	3

# Cleanup
query T
SELECT scenario_drop('with_rowids');
----
true

# ============================================================================
# Test 2: Explicit capture_rowids = true (same as default)
# ============================================================================

query T
SELECT scenario_create('explicit_true', 'Explicit true', true);
----
true

query I
SELECT COUNT(*) FROM _scenario_base_rowids WHERE scenario_id = (
    SELECT scenario_id FROM _scenario_registry WHERE scenario_name = 'explicit_true'
);
----
3

query T
SELECT scenario_drop('explicit_true');
----
true

# ============================================================================
# Test 3: capture_rowids = false skips rowid capture
# ============================================================================

query T
SELECT scenario_create('no_rowids', 'Scenario without rowid capture', false);
----
true

# No rowids should be captured
query I
SELECT COUNT(*) FROM _scenario_base_rowids WHERE scenario_id = (
    SELECT scenario_id FROM _scenario_registry WHERE scenario_name = 'no_rowids'
);
----
0

# Scenario functionality still works
query T
SELECT delta_create('no_rowids', 'rowid_test');
----
true

# Can read the merge view
query I
SELECT COUNT(*) FROM _scen_no_rowids.rowid_test;
----
3

# Can write to delta
statement ok
INSERT INTO _scen_no_rowids._delta_rowid_test (_op, id, value) VALUES ('I', 4, 'four');

# Read includes delta
query I
SELECT COUNT(*) FROM _scen_no_rowids.rowid_test;
----
4

# scenario_validate reports rowid validation skipped
query TTT
SELECT table_name, validation_status, message
FROM scenario_validate('no_rowids');
----
rowid_test	INFO	Rowid validation skipped (capture_rowids=false at creation)

# Cleanup
query T
SELECT scenario_drop('no_rowids');
----
true

# ============================================================================
# Test 4: Performance benefit - no delay for large tables
# ============================================================================

# Create a larger table
statement ok
CREATE TABLE big_test AS SELECT i as id, 'value_' || i as value FROM range(10000) t(i);

# With capture_rowids=false, should be fast (no INSERT of 10000 rows)
query T
SELECT scenario_create('fast_scenario', 'Fast creation', false);
----
true

# Verify no rowids captured
query I
SELECT COUNT(*) FROM _scenario_base_rowids WHERE scenario_id = (
    SELECT scenario_id FROM _scenario_registry WHERE scenario_name = 'fast_scenario'
);
----
0

query T
SELECT scenario_drop('fast_scenario');
----
true

statement ok
DROP TABLE big_test;

# ============================================================================
# Test 5: scenario_branch inherits parent's rowid state
# ============================================================================

# Create parent with rowids
query T
SELECT scenario_create('parent_with', 'Parent with rowids', true);
----
true

query T
SELECT delta_create('parent_with', 'rowid_test');
----
true

# Branch inherits rowids
query T
SELECT scenario_branch('parent_with', 'child_with', 'Child inherits rowids');
----
true

query I
SELECT COUNT(*) FROM _scenario_base_rowids WHERE scenario_id = (
    SELECT scenario_id FROM _scenario_registry WHERE scenario_name = 'child_with'
);
----
3

query T
SELECT scenario_drop('child_with');
----
true

query T
SELECT scenario_drop('parent_with');
----
true

# Create parent without rowids
query T
SELECT scenario_create('parent_without', 'Parent without rowids', false);
----
true

query T
SELECT delta_create('parent_without', 'rowid_test');
----
true

# Branch inherits no-rowids state
query T
SELECT scenario_branch('parent_without', 'child_without', 'Child inherits no-rowids');
----
true

query I
SELECT COUNT(*) FROM _scenario_base_rowids WHERE scenario_id = (
    SELECT scenario_id FROM _scenario_registry WHERE scenario_name = 'child_without'
);
----
0

query T
SELECT scenario_drop('child_without');
----
true

query T
SELECT scenario_drop('parent_without');
----
true

# ============================================================================
# Cleanup
# ============================================================================

statement ok
DROP TABLE rowid_test;

# Final verification
query I
SELECT COUNT(*) FROM scenario_list();
----
0
