# name: test/sql/scenario_comparison.test
# description: Test scenario comparison functionality
# group: [anofox_scenario]

require anofox_scenario

# ===== Setup =====

statement ok
CREATE TABLE products (id INTEGER PRIMARY KEY, name VARCHAR, price DECIMAL(10,2));

statement ok
INSERT INTO products VALUES (1, 'Widget', 9.99), (2, 'Gadget', 19.99), (3, 'Thingamajig', 29.99);

# Create a scenario with delta table
query T
SELECT scenario_create('compare_test', 'Testing scenario comparison');
----
true

query T
SELECT delta_create('compare_test', 'products');
----
true

# ===== Test 1: No differences initially =====

# Verify compare returns empty when no changes
query I
SELECT COUNT(*) FROM scenario_compare('compare_test', 'products');
----
0

# ===== Test 2: Added rows =====

# Insert a new row
statement ok
INSERT INTO _scen_compare_test._delta_products (_op, id, name, price) VALUES ('I', 4, 'NewProduct', 39.99);

# Compare should show added row
query TITTT
SELECT diff_type, id, column_name, old_value, new_value FROM scenario_compare('compare_test', 'products') ORDER BY id;
----
added	4	NULL	NULL	NULL

# ===== Test 3: Removed rows =====

# Delete a row
statement ok
INSERT INTO _scen_compare_test._delta_products (_op, id, name, price) VALUES ('D', 1, 'Widget', 9.99);

# Compare should show removed row
query TITTT
SELECT diff_type, id, column_name, old_value, new_value FROM scenario_compare('compare_test', 'products')
WHERE diff_type = 'removed' ORDER BY id;
----
removed	1	NULL	NULL	NULL

# ===== Test 4: Changed rows =====

# Update a row
statement ok
INSERT INTO _scen_compare_test._delta_products (_op, id, name, price) VALUES ('U', 2, 'UpdatedGadget', 24.99);

# Compare should show changed columns
query TITTT
SELECT diff_type, id, column_name, old_value, new_value FROM scenario_compare('compare_test', 'products')
WHERE diff_type = 'changed' ORDER BY id, column_name;
----
changed	2	name	Gadget	UpdatedGadget
changed	2	price	19.99	24.99

# ===== Test 5: Full comparison output =====

query TITTT
SELECT diff_type, id, column_name, old_value, new_value FROM scenario_compare('compare_test', 'products')
ORDER BY diff_type, id, column_name;
----
added	4	NULL	NULL	NULL
changed	2	name	Gadget	UpdatedGadget
changed	2	price	19.99	24.99
removed	1	NULL	NULL	NULL

# ===== Test 6: Error for non-existent scenario =====

statement error
SELECT * FROM scenario_compare('nonexistent', 'products');
----
does not exist

# ===== Test 7: Error for non-existent table =====

statement error
SELECT * FROM scenario_compare('compare_test', 'nonexistent_table');
----
does not exist

# ===== Test 8: Compare with compound primary key =====

statement ok
CREATE TABLE order_items (order_id INTEGER, product_id INTEGER, quantity INTEGER, PRIMARY KEY (order_id, product_id));

statement ok
INSERT INTO order_items VALUES (1, 100, 5), (1, 101, 3), (2, 100, 7);

query T
SELECT delta_create('compare_test', 'order_items');
----
true

# Insert new row with compound key
statement ok
INSERT INTO _scen_compare_test._delta_order_items (_op, order_id, product_id, quantity) VALUES ('I', 2, 101, 2);

# Delete row with compound key
statement ok
INSERT INTO _scen_compare_test._delta_order_items (_op, order_id, product_id, quantity) VALUES ('D', 1, 100, 5);

# Update row with compound key
statement ok
INSERT INTO _scen_compare_test._delta_order_items (_op, order_id, product_id, quantity) VALUES ('U', 1, 101, 10);

# Verify compound key comparison
query TIITTT
SELECT diff_type, order_id, product_id, column_name, old_value, new_value FROM scenario_compare('compare_test', 'order_items')
ORDER BY diff_type, order_id, product_id, column_name;
----
added	2	101	NULL	NULL	NULL
changed	1	101	quantity	3	10
removed	1	100	NULL	NULL	NULL

# ===== Cleanup =====

query T
SELECT scenario_drop('compare_test');
----
true

statement ok
DROP TABLE products;

statement ok
DROP TABLE order_items;

# ===== Test 9: Branched scenario compares to parent (branch origin) =====

statement ok
CREATE TABLE inventory (sku VARCHAR PRIMARY KEY, qty INTEGER);

statement ok
INSERT INTO inventory VALUES ('A', 100), ('B', 200), ('C', 300);

# Create parent scenario with some changes
query T
SELECT scenario_create('parent_scen', 'Parent scenario');
----
true

query T
SELECT delta_create('parent_scen', 'inventory');
----
true

# Parent: update A, insert D
statement ok
INSERT INTO _scen_parent_scen._delta_inventory (_op, sku, qty) VALUES ('U', 'A', 150);

statement ok
INSERT INTO _scen_parent_scen._delta_inventory (_op, sku, qty) VALUES ('I', 'D', 400);

# Branch from parent
query T
SELECT scenario_branch('parent_scen', 'child_scen', 'Child branched from parent');
----
true

query T
SELECT delta_create('child_scen', 'inventory');
----
true

# Child: update B, delete C (relative to child's view of main)
statement ok
INSERT INTO _scen_child_scen._delta_inventory (_op, sku, qty) VALUES ('U', 'B', 250);

statement ok
INSERT INTO _scen_child_scen._delta_inventory (_op, sku, qty) VALUES ('D', 'C', 300);

# Compare child to its branch origin (parent)
# Should show child's changes compared to parent's view
query TTTT
SELECT diff_type, sku, column_name, new_value FROM scenario_compare('child_scen', 'inventory')
WHERE diff_type IN ('changed', 'removed') ORDER BY diff_type, sku;
----
changed	B	qty	250
removed	C	NULL	NULL

# Cleanup branched test
query T
SELECT scenario_drop('child_scen');
----
true

query T
SELECT scenario_drop('parent_scen');
----
true

statement ok
DROP TABLE inventory;

# ===== Test 10: scenario_compare_all summary =====

statement ok
CREATE TABLE items (id INTEGER PRIMARY KEY, name VARCHAR);

statement ok
INSERT INTO items VALUES (1, 'A'), (2, 'B'), (3, 'C');

statement ok
CREATE TABLE categories (cat_id INTEGER PRIMARY KEY, cat_name VARCHAR);

statement ok
INSERT INTO categories VALUES (10, 'X'), (20, 'Y');

query T
SELECT scenario_create('summary_test', 'Testing compare_all');
----
true

query T
SELECT delta_create('summary_test', 'items');
----
true

query T
SELECT delta_create('summary_test', 'categories');
----
true

# items: 2 inserts, 1 update, 1 delete
statement ok
INSERT INTO _scen_summary_test._delta_items (_op, id, name) VALUES ('I', 4, 'D');

statement ok
INSERT INTO _scen_summary_test._delta_items (_op, id, name) VALUES ('I', 5, 'E');

statement ok
INSERT INTO _scen_summary_test._delta_items (_op, id, name) VALUES ('U', 1, 'A-updated');

statement ok
INSERT INTO _scen_summary_test._delta_items (_op, id, name) VALUES ('D', 2, 'B');

# categories: 1 delete only
statement ok
INSERT INTO _scen_summary_test._delta_categories (_op, cat_id, cat_name) VALUES ('D', 10, 'X');

# Test scenario_compare_all
query TIII
SELECT table_name, added_rows, removed_rows, changed_rows FROM scenario_compare_all('summary_test') ORDER BY table_name;
----
categories	0	1	0
items	2	1	1

# Error for non-existent scenario
statement error
SELECT * FROM scenario_compare_all('nonexistent');
----
does not exist

# Cleanup
query T
SELECT scenario_drop('summary_test');
----
true

statement ok
DROP TABLE items;

statement ok
DROP TABLE categories;

# ===== Test 11: Scenario-to-scenario comparison (3-arg) =====

statement ok
CREATE TABLE data (id INTEGER PRIMARY KEY, val VARCHAR);

statement ok
INSERT INTO data VALUES (1, 'A'), (2, 'B'), (3, 'C');

query T
SELECT scenario_create('left_scen', 'Left scenario');
----
true

query T
SELECT scenario_create('right_scen', 'Right scenario');
----
true

query T
SELECT delta_create('left_scen', 'data');
----
true

query T
SELECT delta_create('right_scen', 'data');
----
true

# Left: update 1, delete 2
statement ok
INSERT INTO _scen_left_scen._delta_data (_op, id, val) VALUES ('U', 1, 'A-left');

statement ok
INSERT INTO _scen_left_scen._delta_data (_op, id, val) VALUES ('D', 2, 'B');

# Right: update 1 differently, insert 4
statement ok
INSERT INTO _scen_right_scen._delta_data (_op, id, val) VALUES ('U', 1, 'A-right');

statement ok
INSERT INTO _scen_right_scen._delta_data (_op, id, val) VALUES ('I', 4, 'D');

# Compare left to right
query TITTT
SELECT diff_type, id, column_name, old_value, new_value
FROM scenario_compare('left_scen', 'right_scen', 'data')
ORDER BY diff_type, id;
----
added	2	NULL	NULL	NULL
added	4	NULL	NULL	NULL
changed	1	val	A-left	A-right

# Error for non-existent scenario
statement error
SELECT * FROM scenario_compare('left_scen', 'nonexistent', 'data');
----
does not exist

# Cleanup
query T
SELECT scenario_drop('left_scen');
----
true

query T
SELECT scenario_drop('right_scen');
----
true

statement ok
DROP TABLE data;
